# ============================================================
# ENVIRONMENT VARIABLES — chatapp-backend
# Copy this to .env and fill in your Azure values
# (These are auto-injected by App Service from Terraform app_settings)
# ============================================================

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=storage3tierapp;AccountKey=<YOUR_KEY>;EndpointSuffix=core.windows.net
TABLE_NAME=appdata
CONTAINER_NAME=appfiles

# Port (Azure App Service sets this automatically)
PORT=3001
